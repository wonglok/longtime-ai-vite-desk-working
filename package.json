{
  "name": "longtime-ai",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "dev": "nodemon --exec \"npm run dev2\" --watch ./src/preload/ --watch ./src/main/ -e ts,js",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "icon": "npx @arcsin1/electron-icon-builder --input=./resources/icon.png --output=./build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev2": "electron-vite dev",
    "deploy:lok": "npm run build:mac",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "APPLE_KEYCHAIN=login APPLE_KEYCHAIN_PROFILE=WONG_LOK_PROFILE electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "afterSign": "scripts/nota.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "1",
    "@ai-sdk/react": "1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@lmstudio/sdk": "^1.5.0",
    "@openai/agents": "^0.5.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.1",
    "ai": "5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "isolated-vm": "^6.0.2",
    "lucide-react": "^0.575.0",
    "make-dir": "^5.1.0",
    "nodemon": "^3.1.14",
    "openai": "^6.25.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.1",
    "trash": "^10.1.1",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shadcn": "^3.8.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
